# Copy to .env and edit. NEVER commit your real .env.

# REQUIRED — shared secret the extension must send with every request.
# Generate one:  openssl rand -hex 24
AGENT_TOKEN=

# Optional — seed the scope (comma-separated host patterns). You can also push
# scope from the extension (Config → Companion Agent → Sync scope).
#   *.example.com = apex + subdomains,  example.com = exact host
AGENT_SCOPE_IN=
AGENT_SCOPE_OUT=

# Optional — set to false to forbid active tools (naabu/nmap/nuclei) entirely.
AGENT_ALLOW_ACTIVE=true

# Optional — max scans per minute.
AGENT_RATE_MAX=30

# Optional — content-discovery wordlist for ffuf/feroxbuster.
AGENT_WORDLIST=/usr/share/wordlists/dirb/common.txt

# Optional — out-of-band interaction catcher (confirms blind SSRF/RCE). Off by
# default; also requires AGENT_ALLOW_ACTIVE=true. HTTP-only, LISTEN-only.
AGENT_OOB_ENABLE=false
AGENT_OOB_PORT=8788
# Bind address for the catcher. 127.0.0.1 (default) catches only same-host
# callbacks (safe). To catch callbacks from an external target you must bind
# wider (e.g. 0.0.0.0) AND set AGENT_OOB_HOST to an address the target can reach
# — this exposes a listener, so only do it deliberately.
AGENT_OOB_BIND=127.0.0.1
# What the payload callback URL points at (host[:port]); defaults to loopback.
AGENT_OOB_HOST=

# Optional — scheduled watches send delta alerts to this webhook (your own
# Discord/Slack/Telegram endpoint). Leave blank for no outbound alerts.
AGENT_WEBHOOK_URL=
AGENT_WEBHOOK_PLATFORM=discord
